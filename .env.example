# =============================================================================
# AstraGate Environment Variables
# Copy this file to .env and fill in the values before running `make dev`.
# NEVER commit .env to version control.
# =============================================================================

# --- Database ---
# Full async connection URL for SQLAlchemy (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://astragate:changeme@postgres:5432/astragate

# Password for the PostgreSQL astragate user
POSTGRES_PASSWORD=changeme

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- LiteLLM Proxy ---
# Internal URL — only reachable within the Docker network
LITELLM_URL=http://litellm:4000

# Master key used by AstraGate to authenticate with LiteLLM Proxy
# Generate with: openssl rand -hex 32
LITELLM_MASTER_KEY=sk-litellm-master-changeme

# --- LLM Provider API Keys (used by LiteLLM Proxy) ---
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- JWT ---
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme-jwt-secret-at-least-32-chars
JWT_REFRESH_SECRET=changeme-jwt-refresh-secret-at-least-32-chars

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Resend (transactional email) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Database Encryption ---
# AES-256 key for encrypting Provider API keys at rest
# Generate with: openssl rand -hex 32
DB_ENCRYPTION_KEY=changeme-db-encryption-key-32-chars

# --- Frontend ---
# Public API URL used by the Next.js dashboard (browser-side)
NEXT_PUBLIC_API_URL=http://localhost:8000
